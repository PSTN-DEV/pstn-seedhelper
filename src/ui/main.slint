import { LineEdit, ComboBox, ScrollView } from "std-widgets.slint";

// ── Design tokens ──────────────────────────────────────────────────────────────
// bg-app:        #0d0d0e   bg-title:      #141414   bg-panel:      #252525
// bg-inset:      #1a1a1a   tab-active:    #3c3c3c   text-primary:  #e5e5e5
// text-secondary:#929292   text-muted:    #6b6b6b   text-disabled: #555555
// brand-red:     #c13520   green-btn:     #3ca96e   green-btn-fg:  #101c12
// blue-toggle:   #4a6bd4   green-accent:  #4ac87a   red-exit-bg:   #3a2020
// red-exit-brd:  #ae3c2c80 red-exit-fg:   #d4816e   green-bar:     #2e9860
// red-bar:       #b04030   border-subtle: #ffffff10

export struct ServerStatus {
    name: string,
    online: bool,
    players: int,
    max-players: int,
    queue: int,
    map: string,
    faction1: string,
    faction2: string,
}

// ── ToggleSwitch ───────────────────────────────────────────────────────────────

component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled(bool);

    width: 42px;
    height: 24px;
    border-radius: 12px;
    background: checked ? #4a6bd4 : #333333;

    ta := TouchArea {
        clicked => { root.checked = !root.checked; root.toggled(root.checked); }
        mouse-cursor: pointer;
    }

    thumb := Rectangle {
        x: root.checked ? 20px : 2px;
        y: 2px;
        width: 20px; height: 20px;
        border-radius: 10px;
        background: #f5f5f5;
        animate x { duration: 150ms; easing: ease-in-out; }
    }
}

// ── ModeToggleRow ──────────────────────────────────────────────────────────────

component ModeToggleRow inherits HorizontalLayout {
    in property <string> label: "";
    in property <string> hint: "";
    in-out property <bool> checked: false;
    callback toggled(bool);

    height: 48px;
    spacing: 0px;
    alignment: space-between;
    padding-bottom: 16px;

    VerticalLayout {
        alignment: center;
        spacing: 2px;
        Text { text: root.label; color: #c9c9c9; font-size: 13.5px; font-weight: 600; }
        Text { text: root.hint;  color: #555555; font-size: 12px; }
    }
    ToggleSwitch { checked <=> root.checked; toggled(v) => { root.toggled(v); } }
}

// ── TimeSelector ───────────────────────────────────────────────────────────────

component TimeSelector inherits HorizontalLayout {
    in-out property <int> hour: 0;
    in-out property <int> minute: 0;

    spacing: 3px;
    height: 34px;
    alignment: center;

    // Hour box
    Rectangle {
        width: 56px; height: 34px;
        background: #252525; border-radius: 7px;
        border-width: 1px; border-color: #ffffff10;
        clip: true;

        HorizontalLayout {
            spacing: 0px;
            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                padding-left: 10px;
                Text {
                    text: root.hour < 10 ? "0\{root.hour}" : "\{root.hour}";
                    font-family: "JetBrains Mono"; font-size: 14px; font-weight: 600;
                    color: #e5e5e5; vertical-alignment: center;
                }
            }
            Rectangle { width: 1px; background: #ffffff10; }
            VerticalLayout {
                width: 20px;
                Rectangle {
                    vertical-stretch: 1;
                    background: hu.has-hover ? #ffffff0d : transparent;
                    hu := TouchArea {
                        clicked => { root.hour = root.hour >= 23 ? 0 : root.hour + 1; }
                        mouse-cursor: pointer;
                    }
                    Text { text: "▲"; font-size: 6px; color: #6b6b6b; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle { height: 1px; background: #ffffff10; }
                Rectangle {
                    vertical-stretch: 1;
                    background: hd.has-hover ? #ffffff0d : transparent;
                    hd := TouchArea {
                        clicked => { root.hour = root.hour <= 0 ? 23 : root.hour - 1; }
                        mouse-cursor: pointer;
                    }
                    Text { text: "▼"; font-size: 6px; color: #6b6b6b; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }

    Text { text: ":"; color: #4a4a4a; font-size: 16px; font-weight: 700; vertical-alignment: center; }

    // Minute box (steps of 5)
    Rectangle {
        width: 56px; height: 34px;
        background: #252525; border-radius: 7px;
        border-width: 1px; border-color: #ffffff10;
        clip: true;

        HorizontalLayout {
            spacing: 0px;
            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                padding-left: 10px;
                Text {
                    text: root.minute < 10 ? "0\{root.minute}" : "\{root.minute}";
                    font-family: "JetBrains Mono"; font-size: 14px; font-weight: 600;
                    color: #e5e5e5; vertical-alignment: center;
                }
            }
            Rectangle { width: 1px; background: #ffffff10; }
            VerticalLayout {
                width: 20px;
                Rectangle {
                    vertical-stretch: 1;
                    background: mu.has-hover ? #ffffff0d : transparent;
                    mu := TouchArea {
                        clicked => { root.minute = root.minute >= 55 ? 0 : root.minute + 5; }
                        mouse-cursor: pointer;
                    }
                    Text { text: "▲"; font-size: 6px; color: #6b6b6b; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle { height: 1px; background: #ffffff10; }
                Rectangle {
                    vertical-stretch: 1;
                    background: md.has-hover ? #ffffff0d : transparent;
                    md := TouchArea {
                        clicked => { root.minute = root.minute <= 0 ? 55 : root.minute - 5; }
                        mouse-cursor: pointer;
                    }
                    Text { text: "▼"; font-size: 6px; color: #6b6b6b; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }
}

// ── SliderRow ──────────────────────────────────────────────────────────────────

component SliderRow inherits HorizontalLayout {
    in property <string> label: "";
    in property <string> hint: "";
    in property <string> unit: "";
    in-out property <int> value: 0;
    in property <int> minimum: 0;
    in property <int> maximum: 100;
    in property <int> step: 1;

    height: 54px;
    spacing: 16px;
    padding-bottom: 12px;

    private property <float> fill-ratio: root.maximum > root.minimum
        ? (root.value - root.minimum) * 1.0 / (root.maximum - root.minimum)
        : 0.0;

    VerticalLayout {
        alignment: center;
        spacing: 2px;
        width: 200px;
        Text { text: root.label; color: #929292; font-size: 13.5px; }
        if root.hint != "" : Text { text: root.hint; color: #444444; font-size: 11px; wrap: word-wrap; }
    }

    Text {
        width: 48px;
        text: "\{root.value}\{root.unit}";
        font-family: "JetBrains Mono"; font-size: 12.5px; font-weight: 600;
        color: #e5e5e5; horizontal-alignment: right; vertical-alignment: center;
    }

    VerticalLayout {
        horizontal-stretch: 1;
        alignment: center;

        track-r := Rectangle {
            height: 5px;
            border-radius: 2.5px;
            background: #2c2c2c;

            Rectangle {
                x: 0px; y: 0px;
                height: parent.height;
                width: parent.width * root.fill-ratio;
                border-radius: 2.5px;
                background: #4a6bd4;
            }

            Rectangle {
                x: clamp(parent.width * root.fill-ratio - 7px, 0px, parent.width - 14px);
                y: (parent.height - 14px) / 2;
                width: 14px; height: 14px;
                border-radius: 7px;
                background: sli.has-hover || sli.pressed ? #ffffff : #d4d4d4;
                animate background { duration: 80ms; }
            }

            sli := TouchArea {
                y: -9px; height: 23px;
                mouse-cursor: ew-resize;

                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) {
                        root.value = root.minimum + round(clamp(self.mouse-x / self.width, 0.0, 1.0) * (root.maximum - root.minimum) / root.step) * root.step;
                        if (root.value > root.maximum) { root.value = root.maximum; }
                        if (root.value < root.minimum) { root.value = root.minimum; }
                    }
                }
                moved => {
                    if (self.pressed) {
                        root.value = root.minimum + round(clamp(self.mouse-x / self.width, 0.0, 1.0) * (root.maximum - root.minimum) / root.step) * root.step;
                        if (root.value > root.maximum) { root.value = root.maximum; }
                        if (root.value < root.minimum) { root.value = root.minimum; }
                    }
                }
            }
        }
    }
}

// ── SettingsRow ────────────────────────────────────────────────────────────────

component SettingsRow inherits HorizontalLayout {
    in property <string> label: "";
    spacing: 16px;
    height: 42px;
    padding-bottom: 14px;

    Text {
        text: root.label; color: #c9c9c9; font-size: 13.5px; font-weight: 600;
        vertical-alignment: center; width: 200px;
    }
    @children
}

// ── ServerRow ──────────────────────────────────────────────────────────────────

component ServerRow inherits Rectangle {
    in property <ServerStatus> status;
    in property <bool> joining-active: false;
    in property <bool> is-pending: false;
    callback join();
    callback cancel-join();

    height: 56px;
    background: #111111; border-width: 1px; border-color: #242424; border-radius: 9px;

    private property <float> fill-pct:
        status.online ? (status.players * 1.0 / (status.max-players > 0 ? status.max-players : 100)) : 0.0;
    private property <color> bar-color:
        (status.online && status.players >= 20) ? #2e9860 : #b04030;

    HorizontalLayout {
        padding-left: 14px; padding-right: 28px; padding-top: 12px; padding-bottom: 12px;
        spacing: 10px;

        Text {
            width: 259px; text: status.name;
            font-family: "JetBrains Mono"; font-size: 13px; font-weight: 700;
            color: #c9c9c9; vertical-alignment: center; overflow: elide;
        }

        // Карта — no clip to avoid sub-pixel blur on high-DPI
        Rectangle {
            width: 160px; background: #1a1a1a; border-radius: 6px;
            Text {
                x: 10px; width: parent.width - 10px;
                text: status.map != "" ? status.map : "—";
                color: #505050; font-size: 12.5px;
                horizontal-alignment: left; vertical-alignment: center; overflow: elide;
            }
        }

        // Фракция 1
        Rectangle {
            width: 80px; background: #1a1a1a; border-radius: 6px;
            Text {
                text: status.faction1 != "" ? status.faction1 : "—";
                color: #505050; font-size: 12px;
                horizontal-alignment: center; vertical-alignment: center; overflow: elide;
            }
        }

        // Фракция 2
        Rectangle {
            width: 80px; background: #1a1a1a; border-radius: 6px;
            Text {
                text: status.faction2 != "" ? status.faction2 : "—";
                color: #505050; font-size: 12px;
                horizontal-alignment: center; vertical-alignment: center; overflow: elide;
            }
        }

        // Заполненность
        Rectangle {
            width: 130px; border-radius: 6px; background: #1a1a1a; clip: true;
            Rectangle {
                x: 0px; y: 0px;
                width: parent.width * root.fill-pct;
                height: parent.height;
                background: root.bar-color;
            }
            Text {
                x: 0px; y: 0px; width: parent.width; height: parent.height;
                text: status.online
                    ? (status.queue > 0
                        ? "\{status.players}/\{status.max-players} (+\{status.queue})"
                        : "\{status.players}/\{status.max-players}")
                    : "Офлайн";
                color: #eee0dc; font-size: 12.5px; font-weight: 700;
                horizontal-alignment: center; vertical-alignment: center;
            }
        }

        // ПОДКЛЮЧИТЬСЯ / ОТМЕНА
        Rectangle {
            width: 150px; border-radius: 6px; border-width: 1px;
            border-color: root.is-pending ? #ae3c2c60
                : (root.joining-active ? #ffffff08
                : (jta.has-hover ? #c9c9c9 : #ffffff1e));
            background: root.is-pending ? #2a1010
                : (root.joining-active ? transparent
                : (jta.has-hover ? #ffffff0d : transparent));
            jta := TouchArea {
                clicked => {
                    if (root.is-pending) { root.cancel-join(); }
                    else if (!root.joining-active) { root.join(); }
                }
                mouse-cursor: (root.is-pending || !root.joining-active) ? pointer : default;
            }
            Text {
                text: root.is-pending ? "ОТМЕНА" : "ПОДКЛЮЧИТЬСЯ";
                color: root.is-pending ? #d4816e
                    : (root.joining-active ? #333333
                    : (jta.has-hover ? #e5e5e5 : #c9c9c9));
                font-size: 12px; font-weight: 600;
                horizontal-alignment: center; vertical-alignment: center;
            }
        }
    }
}

// ── StatusChip ─────────────────────────────────────────────────────────────────

component StatusChip inherits HorizontalLayout {
    in property <string> label: "";
    in property <color>  dot-color: #6b6b6b;
    in property <bool>   glowing: false;

    spacing: 7px; alignment: center;

    VerticalLayout {
        width: 7px; alignment: center;
        Rectangle {
            width: 7px; height: 7px; border-radius: 3.5px;
            background: root.dot-color;
            drop-shadow-blur: root.glowing ? 6px : 0px;
            drop-shadow-color: root.glowing ? root.dot-color.with-alpha(0.4) : transparent;
        }
    }
    Text { text: root.label; color: root.dot-color; font-size: 12.5px; font-weight: 500; vertical-alignment: center; }
}

// ── SectionDivider ─────────────────────────────────────────────────────────────

component SectionDivider inherits VerticalLayout {
    in property <string> text: "";
    spacing: 0px;
    Rectangle { height: 6px; }
    Text { text: root.text; color: #4ac87a; font-size: 12px; font-weight: 700; letter-spacing: 0.6px; }
    Rectangle { height: 8px; }
    Rectangle { height: 1px; background: #ffffff14; }
    Rectangle { height: 14px; }
}

// ── AppWindow ──────────────────────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "Seed Helper v\{root.app-version}";
    icon: @image-url("../../icons/seeder.svg");
    no-frame: true;
    background: transparent;
    min-width: 960px; max-width: 960px; preferred-width: 960px;
    min-height: 780px; preferred-height: 820px;

    // ── Data ──────────────────────────────────────────────────────────────

    in-out property <[ServerStatus]> servers: [
        { name: "PSTN #1 Первый Сервер",      online: false, players: 0, max-players: 100, queue: 0, map: "", faction1: "", faction2: "" },
        { name: "PSTN #2 [RU] ВТОРЖЕНИЕ | ИНВАГА | pstnsquad.ru",              online: false, players: 0, max-players: 100, queue: 0, map: "", faction1: "", faction2: "" },
        { name: "PSTN #3 ВС РФ vs ВСУ 24/7",  online: false, players: 0, max-players: 100, queue: 0, map: "", faction1: "", faction2: "" },
        { name: "PSTN #4 Все режимы",          online: false, players: 0, max-players: 100, queue: 0, map: "", faction1: "", faction2: "" },
    ];

    in-out property <string> log-text: "";
    in-out property <bool>   seeding-active: false;
    in-out property <bool>   stop-blocked: false;
    in-out property <string> remote-seed-order: "";
    in-out property <string> update-notice: "";
    in-out property <bool>   show-confirm-exit: false;
    in-out property <bool>   squad-running: false;
    in-out property <bool>   steam-running: false;
    in-out property <bool>   api-ok: false;
    in-out property <bool>   show-validation-error: false;
    in-out property <string> validation-error-msg: "";
    in-out property <bool>   restore-toast-visible: false;
    in-out property <bool>   refresh-ping: false;
    in-out property <bool>   show-steam-prompt: false;
    in-out property <bool>   show-squad-prompt: false;
    in-out property <int>    pending-join-server: 0;
    in-out property <bool>   joining-active: false;
    in-out property <bool>   show-after-hours-prompt: false;
    in-out property <bool>   after-hours-is-auto: false;
    in-out property <bool>   show-after-seed-confirm: false;
    in-out property <string> after-seed-confirm-msg: "";
    in-out property <string> app-version: "";
    in-out property <bool>   cfg-auto-update: false;
    in-out property <int>    player-server: 0;

    // cfg properties (Rust-bound — names must not change)
    in-out property <string> cfg-steam-id: "";
    in-out property <string> cfg-seed-order-override: "";   // kept for Rust compat, not shown in UI
    in-out property <int>    cfg-desired-players: 65;
    in-out property <int>    cfg-checkup-interval: 60;
    in-out property <int>    cfg-game-launch-delay: 3;
    in-out property <int>    cfg-time-limit: 17;
    in-out property <int>    cfg-time-limit-minute: 0;
    in-out property <bool>   cfg-time-limit-enabled: true;
    in-out property <int>    cfg-startup-wait: 2;
    in-out property <bool>   cfg-start-on-startup: false;
    in-out property <bool>   cfg-auto-start: false;
    in-out property <bool>   cfg-render-toggle: false;
    in-out property <bool>   cfg-auto-create-squad: false;
    in-out property <bool>   cfg-disable-sound: true;
    in-out property <bool>   cfg-delete-startup-video: false;
    in-out property <bool>   cfg-eco-mode: false;
    in-out property <string> cfg-preferred-fps: "";       // empty = None (Squad default)
    in-out property <string> cfg-preferred-menu-fps: ""; // empty = None (Squad default)
    in-out property <string> cfg-preferred-res: "";      // e.g. "1920×1080", auto-detected
    in-out property <string> cfg-after-action: "Ничего";
    in-out property <int>    cfg-stop-after: 0;
    in-out property <string> cfg-scheduled-shutdown: "";    // kept for Rust compat
    in-out property <int>    cfg-shutdown-hour: 0;
    in-out property <int>    cfg-shutdown-minute: 0;
    in-out property <bool>   cfg-shutdown-enabled: false;
    in-out property <bool>   settings-dirty: false;

    // ── Callbacks ─────────────────────────────────────────────────────────

    callback start-seed();
    callback stop-seed();
    callback stop-and-exit();
    callback exit-app();
    callback open-log();
    callback save-settings();
    callback reset-settings();
    callback test-join(int);
    callback apply-update();
    callback open-steam-account();
    callback window-pressed();
    callback window-drag(float, float);
    callback window-drag-ended();
    callback window-minimize();
    callback reload-settings();
    callback open-website();
    callback open-steam-click();
    callback launch-squad-and-join(int);
    callback cancel-squad-join();
    callback force-start-seed();
    callback confirm-after-seed-proceed();
    callback confirm-after-seed-cancel();

    // ── Internal state ────────────────────────────────────────────────────

    private property <int>   active-tab: 0;
    private property <float> popup-alpha: 0.0;
    private property <bool>  show-advanced: false;
    private property <bool>  show-render-confirm: false;
    private property <bool>  show-unsaved-warning: false;
    private property <bool>  show-wait-exit: false;
    private property <int>   exit-wait-secs: 10;
    private property <int>   refresh-elapsed: 0;
    private property <float> refresh-fill: root.cfg-checkup-interval > 0
        ? clamp(1.0 - refresh-elapsed * 1.0 / root.cfg-checkup-interval, 0.0, 1.0)
        : 0.0;

    // ── Dirty tracking (fires when any cfg-* changes; Rust resets after sync) ──
    changed cfg-steam-id             => { root.settings-dirty = true; }
    changed cfg-desired-players      => { root.settings-dirty = true; }
    changed cfg-checkup-interval     => { root.settings-dirty = true; }
    changed cfg-game-launch-delay    => { root.settings-dirty = true; }
    changed cfg-time-limit           => { root.settings-dirty = true; }
    changed cfg-time-limit-minute    => { root.settings-dirty = true; }
    changed cfg-time-limit-enabled   => { root.settings-dirty = true; }
    changed cfg-startup-wait         => { root.settings-dirty = true; }
    changed cfg-start-on-startup     => { root.settings-dirty = true; }
    changed cfg-auto-start           => { root.settings-dirty = true; }
    changed cfg-render-toggle        => { root.settings-dirty = true; }
    changed cfg-auto-create-squad    => { root.settings-dirty = true; }
    changed cfg-disable-sound        => { root.settings-dirty = true; }
    changed cfg-delete-startup-video => { root.settings-dirty = true; }
    changed cfg-eco-mode             => { root.settings-dirty = true; }
    changed cfg-preferred-fps        => { root.settings-dirty = true; }
    changed cfg-preferred-menu-fps   => { root.settings-dirty = true; }
    changed cfg-after-action         => { root.settings-dirty = true; }
    changed cfg-stop-after           => { root.settings-dirty = true; }
    changed cfg-shutdown-hour        => { root.settings-dirty = true; }
    changed cfg-shutdown-minute      => { root.settings-dirty = true; }
    changed cfg-shutdown-enabled     => { root.settings-dirty = true; }
    changed cfg-auto-update          => { root.settings-dirty = true; }
    changed refresh-ping             => { refresh-elapsed = 0; }
    changed log-text                 => { log-flick.viewport-y = min(0px, log-flick.height - log-flick.viewport-height); }
    changed stop-blocked             => { if (!root.stop-blocked && root.show-wait-exit) { root.show-wait-exit = false; root.show-confirm-exit = true; } }
    animate popup-alpha { duration: 220ms; easing: ease-out; }
    private property <float> restore-toast-alpha: restore-toast-visible ? 1.0 : 0.0;
    animate restore-toast-alpha { duration: 220ms; easing: ease-out; }

    // ── Shell ─────────────────────────────────────────────────────────────

    Rectangle {
        border-width: 1px; border-color: #ffffff0f;
        border-radius: 14px; background: #0d0d0e; clip: true;

    refresh-countdown := Timer {
        interval: 1000ms;
        running: true;
        triggered => {
            refresh-elapsed = refresh-elapsed < root.cfg-checkup-interval
                ? refresh-elapsed + 1
                : root.cfg-checkup-interval;
        }
    }

    save-toast-timer := Timer {
        interval: 2500ms;
        running: false;
        triggered => {
            root.popup-alpha = 0.0;
            save-toast-timer.running = false;
        }
    }

    restore-toast-timer := Timer {
        interval: 2500ms;
        running: root.restore-toast-visible;
        triggered => { root.restore-toast-visible = false; }
    }

    exit-wait-timer := Timer {
        interval: 1000ms;
        running: root.show-wait-exit && root.exit-wait-secs > 0;
        triggered => { root.exit-wait-secs = root.exit-wait-secs - 1; }
    }

    VerticalLayout { spacing: 0px; padding: 0px;

        // ── Title bar ──────────────────────────────────────────────────────
        Rectangle {
            height: 36px;
            background: #0d0d0e;

            HorizontalLayout {
                padding-left: 14px; padding-right: 0px; spacing: 8px;

                Rectangle {
                    width: 130px;
                    logo-ta := TouchArea { clicked => { root.open-website(); } mouse-cursor: pointer; }
                    HorizontalLayout {
                        spacing: 8px;
                        VerticalLayout {
                            width: 22px; alignment: center;
                            Image {
                                source: @image-url("../../icons/seeder.svg");
                                width: 22px; height: 22px; image-fit: contain;
                            }
                        }
                        VerticalLayout {
                            alignment: center; spacing: 0px;
                            Text { text: "Seed Helper"; color: logo-ta.has-hover ? #c13520 : #e5e5e5; font-size: 13px; font-weight: 600; }
                            Text { text: "v\{root.app-version}"; color: #6b6b6b; font-family: "JetBrains Mono"; font-size: 10px; }
                        }
                    }
                }

                drag-area := TouchArea {
                    horizontal-stretch: 1;
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) { root.window-pressed(); content-focus.focus(); }
                        else if (e.kind == PointerEventKind.up) { root.window-drag-ended(); }
                    }
                    moved => {
                        if (self.pressed) {
                            root.window-drag(
                                (self.mouse-x - self.pressed-x) / 1px,
                                (self.mouse-y - self.pressed-y) / 1px
                            );
                        }
                    }
                }

                Rectangle {
                    width: 40px; height: 36px;
                    background: minta.has-hover ? #2a2a2a : transparent;
                    minta := TouchArea { clicked => { root.window-minimize(); } mouse-cursor: pointer; }
                    Image {
                        source: @image-url("../../icons/minus.svg");
                        width: 11px; height: 11px;
                        colorize: minta.has-hover ? #e5e5e5 : #6b6b6b;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }

                Rectangle {
                    width: 40px; height: 36px;
                    background: clsta.has-hover ? #c42b1c : transparent;
                    clsta := TouchArea {
                        clicked => {
                            if (root.seeding-active) {
                                if (root.stop-blocked) {
                                    root.exit-wait-secs = 10;
                                    root.show-wait-exit = true;
                                } else {
                                    root.show-confirm-exit = true;
                                }
                            } else {
                                root.exit-app();
                            }
                        }
                        mouse-cursor: pointer;
                    }
                    Image {
                        source: @image-url("../../icons/x.svg");
                        width: 11px; height: 11px;
                        colorize: clsta.has-hover ? #ffffff : #6b6b6b;
                        image-fit: contain;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }
        }

        // ── Update banner
        if root.update-notice != "" : Rectangle {
            height: 30px; background: #1d4ed8;
            HorizontalLayout {
                padding-left: 12px; padding-right: 8px; spacing: 8px; alignment: center;
                Text { text: root.update-notice; color: white; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; }
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 80px; height: 22px; background: #2563eb; border-radius: 4px;
                        TouchArea { clicked => { root.apply-update(); } mouse-cursor: pointer; }
                        Text { text: "Обновить"; color: white; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }

        // ── Nav tabs
        Rectangle {
            height: 42px; background: #0d0d0e;

            HorizontalLayout {
                padding: 5px; spacing: 0px;

                Rectangle {
                    height: 32px; background: #1c1c1c; border-radius: 10px;

                    HorizontalLayout {
                        padding: 4px; spacing: 5px;

                        Rectangle {
                            horizontal-stretch: 1; border-radius: 7px;
                            background: root.active-tab == 0 ? #3c3c3c : (nav0.has-hover ? #ffffff08 : transparent);
                            nav0 := TouchArea {
                                clicked => {
                                    if (root.active-tab == 1 && root.settings-dirty) {
                                        root.show-unsaved-warning = true;
                                    } else {
                                        root.active-tab = 0;
                                        content-focus.focus();
                                    }
                                }
                                mouse-cursor: pointer;
                            }
                            Text {
                                text: "Главная";
                                color: root.active-tab == 0 ? #f5f5f5 : #6b6b6b;
                                font-size: 13px; font-weight: 600;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1; border-radius: 7px;
                            background: root.active-tab == 1 ? #3c3c3c : (nav1.has-hover ? #ffffff08 : transparent);
                            nav1 := TouchArea { clicked => { root.active-tab = 1; content-focus.focus(); } mouse-cursor: pointer; }
                            Text {
                                text: "Настройки";
                                color: root.active-tab == 1 ? #f5f5f5 : #6b6b6b;
                                font-size: 13px; font-weight: 600;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
        Rectangle { height: 1px; background: #ffffff0a; }

        // ── Tab content ────────────────────────────────────────────────────
        Rectangle { vertical-stretch: 1; clip: true;

        content-focus := FocusScope {
            x: 0; y: 0; width: parent.width; height: parent.height;
            key-pressed(e) => { reject }

        // ГЛАВНАЯ
        VerticalLayout {
            x: 0; y: 0; width: parent.width; height: parent.height;
            visible: root.active-tab == 0;
            spacing: 0px; padding: 16px; padding-top: 14px;

            HorizontalLayout {
                height: 44px; spacing: 10px;

                Rectangle {
                    horizontal-stretch: 1; border-radius: 9px;
                    background: root.seeding-active
                        ? (root.stop-blocked ? #5a2828 : (seedta.has-hover ? #b54040 : #a13a3a))
                        : (seedta.has-hover ? #46c07a : #3ca96e);
                    seedta := TouchArea {
                        clicked => {
                            if (root.seeding-active) {
                                if (!root.stop-blocked) { root.stop-seed(); }
                            } else { root.start-seed(); }
                        }
                        mouse-cursor: (root.seeding-active && root.stop-blocked) ? default : pointer;
                    }
                    Text {
                        text: root.seeding-active ? "Остановить" : "Начать Seed";
                        color: (root.seeding-active && root.stop-blocked) ? #7a5555 : (root.seeding-active ? #f5e5e0 : #101c12);
                        font-size: 14.5px; font-weight: 700;
                        horizontal-alignment: center; vertical-alignment: center; letter-spacing: 0.2px;
                    }
                    if (root.seeding-active && root.stop-blocked) : Image {
                        source: @image-url("../../icons/ban.svg");
                        width: 16px; height: 16px;
                        colorize: #7a5555;
                        image-fit: contain;
                        x: 14px;
                        y: (parent.height - self.height) / 2;
                    }
                }

                Rectangle {
                    horizontal-stretch: 1; border-radius: 9px;
                    background: root.seeding-active
                        ? (root.stop-blocked ? #5a2828 : (extta.has-hover ? #b54040 : #a13a3a))
                        : (extta.has-hover ? #4a2828 : #3a2020);
                    extta := TouchArea {
                        clicked => {
                            if (root.seeding-active) {
                                if (!root.stop-blocked) { root.show-confirm-exit = true; }
                            } else { root.exit-app(); }
                        }
                        mouse-cursor: (root.seeding-active && root.stop-blocked) ? default : pointer;
                    }
                    Text {
                        text: root.seeding-active ? "Остановить и Выйти" : "Выйти";
                        color: (root.seeding-active && root.stop-blocked) ? #7a5555 : (root.seeding-active ? #f5e5e0 : #d4816e);
                        font-size: 14.5px; font-weight: 700;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                    if (root.seeding-active && root.stop-blocked) : Image {
                        source: @image-url("../../icons/ban.svg");
                        width: 16px; height: 16px;
                        colorize: #7a5555;
                        image-fit: contain;
                        x: 14px;
                        y: (parent.height - self.height) / 2;
                    }
                }

                Rectangle {
                    width: 150px; border-radius: 9px;
                    background: logta.has-hover ? #2e2e2e : #272727;
                    border-width: 1px; border-color: #ffffff0f;
                    logta := TouchArea { clicked => { root.open-log(); } mouse-cursor: pointer; }
                    Text {
                        text: "ЛОГ ФАЙЛ";
                        color: logta.has-hover ? #929292 : #555555;
                        font-size: 13px; font-weight: 600;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 110px; border-radius: 9px;
                    background: #272727;
                    border-width: 1px; border-color: #ffffff0f;
                    clip: false;
                    Text {
                        text: "v\{root.app-version}";
                        color: #555555;
                        font-size: 12px; font-weight: 600;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                    if root.update-notice != "" : Rectangle {
                        x: parent.width - 8px;
                        y: -4px;
                        width: 12px; height: 12px;
                        border-radius: 6px;
                        background: #c13520;
                        border-width: 2px; border-color: #0d0d0e;
                    }
                }
            }

            Rectangle { height: 12px; }

            Rectangle {
                height: 44px; background: #111111; border-radius: 9px;
                border-width: 1px; border-color: #242424;
                HorizontalLayout {
                    padding-left: 22px; padding-right: 22px; spacing: 0px; alignment: space-between;
                    StatusChip {
                        label: root.seeding-active ? "Seed Helper активен" : "Seed Helper выключен";
                        dot-color: root.seeding-active ? #4ac87a : #6b6b6b;
                        glowing: root.seeding-active;
                    }
                    StatusChip {
                        label: root.squad-running ? "Squad запущен" : "Squad не запущен";
                        dot-color: root.squad-running ? #4ac87a : #6b6b6b;
                        glowing: root.squad-running;
                    }
                    StatusChip {
                        label: root.steam-running ? "Steam запущен" : "Steam не запущен";
                        dot-color: root.steam-running ? #4ac87a : #6b6b6b;
                        glowing: root.steam-running;
                    }
                    StatusChip {
                        label: root.player-server > 0 ? "На сервере #\{root.player-server}" : "Не на сервере";
                        dot-color: root.player-server > 0 ? #4ac87a : #6b6b6b;
                        glowing: root.player-server > 0;
                    }
                    StatusChip {
                        label: root.api-ok ? "API OK" : "API недоступен";
                        dot-color: root.api-ok ? #50cc7e : #b04030;
                        glowing: root.api-ok;
                    }
                }
            }

            Rectangle { height: 14px; }

            HorizontalLayout {
                height: 24px; spacing: 8px;
                Text { text: "СТАТУС СЕРВЕРОВ"; color: #6b6b6b; font-size: 11.5px; font-weight: 600; letter-spacing: 0.6px; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; }
                HorizontalLayout {
                    alignment: center; spacing: 4px;
                    VerticalLayout {
                        alignment: center;
                        Image {
                            width: 11px; height: 11px;
                            source: @image-url("../../icons/rotate-cw.svg");
                            colorize: #444444;
                        }
                    }
                    Text {
                        text: "\{root.cfg-checkup-interval - root.refresh-elapsed}s";
                        color: #444444; font-size: 11px; font-weight: 500;
                        vertical-alignment: center;
                    }
                }
            }

            HorizontalLayout {
                height: 24px; padding-left: 14px; padding-right: 14px; spacing: 10px;
                Text { width: 264px; text: "Сервер";        color: #404040; font-size: 10.5px; font-weight: 600; vertical-alignment: center; }
                Text { width: 160px; text: "Карта";         color: #404040; font-size: 10.5px; font-weight: 600; horizontal-alignment: left; vertical-alignment: center; }
                Text { width: 80px;  text: "Команда 1";    color: #404040; font-size: 10.5px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                Text { width: 80px;  text: "Команда 2";    color: #404040; font-size: 10.5px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                Text { width: 130px; text: "Заполненность"; color: #404040; font-size: 10.5px; font-weight: 600; vertical-alignment: center; }
                Text { width: 150px; text: ""; }
            }

            VerticalLayout {
                spacing: 8px; padding-bottom: 12px;
                ServerRow {
                    status: root.servers[0];
                    joining-active: root.joining-active || root.seeding-active;
                    is-pending: root.joining-active && root.pending-join-server == 1;
                    join => {
                        root.pending-join-server = 1;
                        if (!root.steam-running) { root.show-steam-prompt = true; }
                        else if (!root.squad-running) { root.show-squad-prompt = true; }
                        else { root.test-join(1); }
                    }
                    cancel-join => { root.cancel-squad-join(); }
                }
                ServerRow {
                    status: root.servers[1];
                    joining-active: root.joining-active || root.seeding-active;
                    is-pending: root.joining-active && root.pending-join-server == 2;
                    join => {
                        root.pending-join-server = 2;
                        if (!root.steam-running) { root.show-steam-prompt = true; }
                        else if (!root.squad-running) { root.show-squad-prompt = true; }
                        else { root.test-join(2); }
                    }
                    cancel-join => { root.cancel-squad-join(); }
                }
                ServerRow {
                    status: root.servers[2];
                    joining-active: root.joining-active || root.seeding-active;
                    is-pending: root.joining-active && root.pending-join-server == 3;
                    join => {
                        root.pending-join-server = 3;
                        if (!root.steam-running) { root.show-steam-prompt = true; }
                        else if (!root.squad-running) { root.show-squad-prompt = true; }
                        else { root.test-join(3); }
                    }
                    cancel-join => { root.cancel-squad-join(); }
                }
                ServerRow {
                    status: root.servers[3];
                    joining-active: root.joining-active || root.seeding-active;
                    is-pending: root.joining-active && root.pending-join-server == 4;
                    join => {
                        root.pending-join-server = 4;
                        if (!root.steam-running) { root.show-steam-prompt = true; }
                        else if (!root.squad-running) { root.show-squad-prompt = true; }
                        else { root.test-join(4); }
                    }
                    cancel-join => { root.cancel-squad-join(); }
                }
            }

            HorizontalLayout {
                height: 20px;
                Text { text: "ЛОГИ"; color: #6b6b6b; font-size: 11.5px; font-weight: 600; letter-spacing: 0.6px; vertical-alignment: center; }
            }

            Rectangle { height: 6px; }

            Rectangle {
                vertical-stretch: 1; min-height: 160px;
                background: #141414; border-radius: 9px;
                border-width: 1px; border-color: #ffffff0a; clip: true;

                log-flick := ScrollView {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    viewport-height: log-inner.preferred-height + 28px;
                    viewport-width: parent.width;

                    log-inner := Text {
                        x: 16px; y: 14px;
                        width: parent.width - 48px;
                        text: root.log-text;
                        font-family: "JetBrains Mono"; font-size: 12px;
                        color: #6b8faa;
                        wrap: word-wrap;
                    }
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════
        // НАСТРОЙКИ — Flickable для плавного скролла
        // ══════════════════════════════════════════════════════════════════
        Flickable {
            x: 0; y: 0; width: parent.width; height: parent.height;
            visible: root.active-tab == 1;
            viewport-height: settings-layout.preferred-height + 44px;

            TouchArea {
                x: 0; y: 0;
                width: parent.width;
                height: max(parent.height, settings-layout.preferred-height + 44px);
                clicked => { content-focus.focus(); }
            }

            settings-layout := VerticalLayout {
                width: parent.width;
                padding: 22px; padding-top: 16px; spacing: 0px; alignment: start;

                // ── Общие настройки ────────────────────────────────────────

                SectionDivider { text: "ОБЩИЕ НАСТРОЙКИ"; }

                SettingsRow { label: "Steam ID (17 цифр):";
                    HorizontalLayout {
                        spacing: 8px;
                        LineEdit { text <=> root.cfg-steam-id; width: 220px; height: 34px; font-family: "JetBrains Mono"; }
                        Rectangle {
                            width: 268px; height: 34px; border-radius: 8px;
                            background: steamta.has-hover ? #2a2a3a : #1e1e2a;
                            border-width: 1px; border-color: steamta.has-hover ? #4a6bd480 : #4a6bd430;
                            steamta := TouchArea { clicked => { root.open-steam-account(); } mouse-cursor: pointer; }
                            Text {
                                text: "Открыть детали аккаунта через Steam-клиент";
                                color: steamta.has-hover ? #8899cc : #4a6bd4;
                                font-size: 11px; font-weight: 600;
                                horizontal-alignment: center; vertical-alignment: center;
                                wrap: word-wrap;
                                x: 8px; width: parent.width - 16px; height: parent.height;
                            }
                        }
                    }
                }
                Rectangle { height: 14px; }

                SettingsRow { label: "Действие после Сида:";
                    ComboBox {
                        width: 220px; height: 34px;
                        model: ["Ничего", "Закрыть игру и Выйти (Рекомендуется)", "Завершение Работы", "Спящий Режим"];
                        current-value <=> root.cfg-after-action;
                    }
                }
                Rectangle { height: 14px; }

                SettingsRow { label: "Остановиться после:";
                    ComboBox {
                        width: 280px; height: 34px;
                        model: ["Не останавливаться", "PSTN #1", "PSTN #2", "PSTN #3", "PSTN #4"];
                        current-index <=> root.cfg-stop-after;
                    }
                }

                // ── Настройки приложения ────────────────────────────────────

                SectionDivider { text: "НАСТРОЙКИ ПРИЛОЖЕНИЯ"; }

                ModeToggleRow {
                    label: "Автозагрузка";
                    hint: "Запускать приложение вместе с Windows";
                    checked <=> root.cfg-start-on-startup;
                }

                ModeToggleRow {
                    label: "Авто-старт Seed";
                    hint: "Автоматически начинать seeding при запуске приложения";
                    checked <=> root.cfg-auto-start;
                }

                ModeToggleRow {
                    label: "Авто-обновление";
                    hint: "Автоматически применять обновления при запуске приложения";
                    checked <=> root.cfg-auto-update;
                }

                // Never start seeding after
                HorizontalLayout {
                    height: 42px; spacing: 16px; padding-bottom: 14px;
                    Text { text: "Не начинать после:"; color: #929292; font-size: 13.5px; vertical-alignment: center; width: 200px; }
                    HorizontalLayout {
                        spacing: 12px;
                        if root.cfg-time-limit-enabled : TimeSelector {
                            hour <=> root.cfg-time-limit;
                            minute <=> root.cfg-time-limit-minute;
                        }
                        if !root.cfg-time-limit-enabled : VerticalLayout {
                            alignment: center;
                            Text { text: "Без ограничений"; color: #555555; font-size: 13px; }
                        }
                        VerticalLayout { alignment: center; ToggleSwitch { checked <=> root.cfg-time-limit-enabled; } }
                    }
                }

                // ── Настройки игры ──────────────────────────────────────────

                SectionDivider { text: "НАСТРОЙКИ ИГРЫ"; }

                ModeToggleRow {
                    label: "Eco-режим";
                    hint: "Запускает Squad в маленьком окне и ограничем FPS. Нельзя начать просто играть.";
                    checked <=> root.cfg-eco-mode;
                }

                if root.cfg-eco-mode : VerticalLayout {
                    spacing: 0px; padding-bottom: 8px;
                    SettingsRow { label: "FPS в игре после сида:";
                        HorizontalLayout {
                            spacing: 8px;
                            LineEdit {
                                text <=> root.cfg-preferred-fps;
                                width: 100px; height: 34px;
                                font-family: "JetBrains Mono";
                                placeholder-text: "По умолчанию";
                            }
                            VerticalLayout {
                                alignment: center;
                                Text { text: "Пусто = Squad сбрасывает сам"; color: #555555; font-size: 11px; }
                            }
                        }
                    }
                    SettingsRow { label: "FPS в главном меню:";
                        HorizontalLayout {
                            spacing: 8px;
                            LineEdit {
                                text <=> root.cfg-preferred-menu-fps;
                                width: 100px; height: 34px;
                                font-family: "JetBrains Mono";
                                placeholder-text: "По умолчанию";
                            }
                            VerticalLayout {
                                alignment: center;
                                Text { text: "Пусто = Squad сбрасывает сам"; color: #555555; font-size: 11px; }
                            }
                        }
                    }
                    SettingsRow { label: "Разрешение экрана:";
                        HorizontalLayout {
                            spacing: 12px;
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: root.cfg-preferred-res != "" ? root.cfg-preferred-res : "Не определено";
                                    color: root.cfg-preferred-res != "" ? #e5e5e5 : #555555;
                                    font-family: "JetBrains Mono"; font-size: 13px; font-weight: 600;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                Text { text: "Определено автоматически — восстанавливается после сида"; color: #555555; font-size: 11px; }
                            }
                        }
                    }
                }

                ModeToggleRow { label: "Отключить звук"; hint: "Запускает Squad без звука"; checked <=> root.cfg-disable-sound; }

                ModeToggleRow {
                    label: "Удалить стартовое видео";
                    hint: "Удаляет интро 'Welcome to Squad!' перед запуском.";
                    checked <=> root.cfg-delete-startup-video;
                }
                // ── Advanced section (chevron collapsible) ─────────────────
                Rectangle {
                    height: 36px;
                    background: adv-ta.has-hover ? #ffffff06 : transparent;
                    border-radius: 6px;
                    adv-ta := TouchArea {
                        clicked => { root.show-advanced = !root.show-advanced; }
                        mouse-cursor: pointer;
                    }
                    HorizontalLayout {
                        padding-left: 2px; spacing: 8px; alignment: start;
                        VerticalLayout {
                            alignment: center;
                            Image {
                                source: root.show-advanced
                                    ? @image-url("../../icons/chevron-down.svg")
                                    : @image-url("../../icons/chevron-right.svg");
                                width: 14px; height: 14px;
                                colorize: #4ac87a;
                                image-fit: contain;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "ДОПОЛНИТЕЛЬНЫЕ ПАРАМЕТРЫ";
                                color: #4ac87a; font-size: 12px; font-weight: 700; letter-spacing: 0.6px;
                            }
                        }
                    }
                }
                Rectangle { height: 1px; background: #ffffff14; }
                Rectangle { height: 14px; }

                if root.show-advanced : VerticalLayout {
                    spacing: 0px;

                    ModeToggleRow { label: "Создать сквад"; hint: "Кратко переключает Squad для создания отряда через консоль"; checked <=> root.cfg-auto-create-squad; }

                    SliderRow {
                        label: "Порог игроков:";
                        hint: "После выбранного количества игроков программа перейдет на следующий сервер";
                        unit: ""; value <=> root.cfg-desired-players; minimum: 30; maximum: 85; step: 5;
                    }
                    SliderRow {
                        label: "Интервал проверки:";
                        hint: "Как часто проходит проверка количества игроков и подключения";
                        unit: "с"; value <=> root.cfg-checkup-interval; minimum: 30; maximum: 180; step: 30;
                    }
                    SliderRow {
                        label: "Задержка запуска:";
                        hint: "Длительность ожидания запуска игры перед подключением к серверу";
                        unit: "м"; value <=> root.cfg-game-launch-delay; minimum: 1; maximum: 10; step: 1;
                    }
                    SliderRow {
                        label: "Ожидание автозапуска:";
                        hint: "Длительность ожидания загрузки Windows после старта при Автозагрузке";
                        unit: "м"; value <=> root.cfg-startup-wait; minimum: 0; maximum: 10; step: 1;
                    }

                    // Завершить сидинг в
                    HorizontalLayout {
                        height: 42px; spacing: 16px; padding-bottom: 14px;
                        Text { text: "Завершить seeding в:"; color: #929292; font-size: 13.5px; vertical-alignment: center; width: 200px; }
                        HorizontalLayout {
                            spacing: 12px;
                            if root.cfg-shutdown-enabled : TimeSelector {
                                hour <=> root.cfg-shutdown-hour;
                                minute <=> root.cfg-shutdown-minute;
                            }
                            if !root.cfg-shutdown-enabled : VerticalLayout {
                                alignment: center;
                                Text { text: "Выключено"; color: #555555; font-size: 13px; }
                            }
                            VerticalLayout { alignment: center; ToggleSwitch { checked <=> root.cfg-shutdown-enabled; } }
                        }
                    }

                    SectionDivider { text: "ЭКСПЕРИМЕНТАЛЬНО"; }

                    ModeToggleRow {
                        label: "Без рендера (ЭКСПЕРИМ.)";
                        hint: "НЕСТАБИЛЬНО! Может взорвать компьютер и сломать все настройки! Использовать на свой страх и риск!";
                        checked <=> root.cfg-render-toggle;
                        toggled(v) => {
                            if (v) {
                                root.cfg-render-toggle = false;
                                root.show-render-confirm = true;
                            }
                        }
                    }
                }

                // ── Save / Reset ───────────────────────────────────────────

                Rectangle { height: 14px; }

                HorizontalLayout {
                    height: 44px; spacing: 10px; alignment: center;

                    Rectangle {
                        width: 220px; border-radius: 9px;
                        background: savta.has-hover ? #46c07a : #3ca96e;
                        savta := TouchArea {
                            clicked => {
                                root.save-settings();
                                root.popup-alpha = 1.0;
                                save-toast-timer.running = true;
                            }
                            mouse-cursor: pointer;
                        }
                        Text { text: "Сохранить Настройки"; color: #101c12; font-size: 14px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    }

                    Rectangle {
                        width: 130px; border-radius: 9px;
                        background: rstta.has-hover ? #333333 : #272727;
                        border-width: 1px; border-color: #ffffff10;
                        rstta := TouchArea { clicked => { root.reset-settings(); } mouse-cursor: pointer; }
                        Text { text: "Сбросить"; color: #6b6b6b; font-size: 13px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                Rectangle { height: 22px; }
            }
        }

        } // end content FocusScope
        } // end tab wrapper
    } // end VerticalLayout

    // ── Settings-saved toast (highest z, floats over all content) ─────────────
    Rectangle {
        x: (parent.width - 290px) / 2;
        y: parent.height - 68px;
        width: 290px; height: 44px;
        border-radius: 10px;
        background: #1a3520;
        border-width: 1px; border-color: #3ca96e50;
        drop-shadow-blur: 12px; drop-shadow-color: #00000060;
        opacity: root.popup-alpha;

        HorizontalLayout {
            spacing: 10px; alignment: center;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 8px; height: 8px; border-radius: 4px;
                    background: #4ac87a;
                    drop-shadow-blur: 6px; drop-shadow-color: #4ac87a80;
                }
            }
            Text {
                text: "Настройки сохранены";
                color: #4ac87a; font-size: 13px; font-weight: 600;
                vertical-alignment: center;
            }
        }
    }

    // ── Settings-restored toast ────────────────────────────────────────────────
    Rectangle {
        x: (parent.width - 300px) / 2;
        y: parent.height - 120px;
        width: 300px; height: 44px;
        border-radius: 10px;
        background: #1a2535;
        border-width: 1px; border-color: #4a6bd450;
        drop-shadow-blur: 12px; drop-shadow-color: #00000060;
        opacity: root.restore-toast-alpha;

        HorizontalLayout {
            spacing: 10px; alignment: center;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 8px; height: 8px; border-radius: 4px;
                    background: #4a6bd4;
                    drop-shadow-blur: 6px; drop-shadow-color: #4a6bd480;
                }
            }
            Text {
                text: "Настройки восстановлены";
                color: #4a6bd4; font-size: 13px; font-weight: 600;
                vertical-alignment: center;
            }
        }
    }

    // ── Wait-for-restore popup (X clicked while settings not yet restored) ────
    if root.show-wait-exit : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #00000099;

        TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

        Rectangle {
            x: (parent.width - 430px) / 2;
            y: (parent.height - 200px) / 2;
            width: 430px; height: 200px;
            border-radius: 14px;
            background: #252525;
            border-width: 1px; border-color: #ffffff18;
            drop-shadow-blur: 48px; drop-shadow-color: #000000cc;

            TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

            VerticalLayout {
                padding: 26px; spacing: 0px;

                Text {
                    text: "Восстановление настроек...";
                    color: #e5e5e5; font-size: 15px; font-weight: 700;
                }
                Rectangle { height: 8px; }
                Text {
                    text: "Настройки игры ещё не восстановлены. Пожалуйста, подождите.";
                    color: #6b6b6b; font-size: 13px; wrap: word-wrap;
                }
                Rectangle { height: 16px; }

                HorizontalLayout {
                    spacing: 0px; alignment: center;
                    Text {
                        text: "\{root.exit-wait-secs}";
                        color: #4a6bd4; font-size: 36px; font-weight: 700;
                        font-family: "JetBrains Mono";
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }
                Rectangle { height: 16px; }

                HorizontalLayout {
                    height: 38px; alignment: end;
                    Rectangle {
                        width: 115px; border-radius: 9px;
                        background: wex-cancel.has-hover ? #333333 : #2c2c2c;
                        border-width: 1px; border-color: #ffffff14;
                        wex-cancel := TouchArea {
                            clicked => { root.show-wait-exit = false; }
                            mouse-cursor: pointer;
                        }
                        Text {
                            text: "Отмена";
                            color: #929292; font-size: 13.5px; font-weight: 600;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ── Stop & Exit confirmation dialog ────────────────────────────────────────
    if root.show-confirm-exit : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #00000099;

        // Absorbs all clicks that fall outside the dialog card
        TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

        // Dialog card (higher z than backdrop absorber)
        Rectangle {
            x: (parent.width - 430px) / 2;
            y: (parent.height - 190px) / 2;
            width: 430px; height: 190px;
            border-radius: 14px;
            background: #252525;
            border-width: 1px; border-color: #ffffff18;
            drop-shadow-blur: 48px; drop-shadow-color: #000000cc;

            // Absorbs clicks on card body so they don't reach the backdrop TouchArea
            TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

            VerticalLayout {
                padding: 26px; spacing: 0px;

                Text {
                    text: "Выйти из приложения?";
                    color: #e5e5e5; font-size: 15px; font-weight: 700;
                }
                Rectangle { height: 8px; }
                Text {
                    text: "Seeding будет остановлен, Squad закроется, а настройки будут восстановлены.";
                    color: #6b6b6b; font-size: 13px; wrap: word-wrap;
                }
                Rectangle { height: 22px; }

                HorizontalLayout {
                    spacing: 10px; height: 42px;

                    Rectangle {
                        horizontal-stretch: 1; border-radius: 9px;
                        background: cnfta.has-hover ? #b54040 : #a13a3a;
                        cnfta := TouchArea {
                            clicked => {
                                root.show-confirm-exit = false;
                                root.stop-and-exit();
                            }
                            mouse-cursor: pointer;
                        }
                        Text {
                            text: "Да, выйти";
                            color: #f5e5e0; font-size: 13.5px; font-weight: 700;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 115px; border-radius: 9px;
                        background: cncta.has-hover ? #333333 : #2c2c2c;
                        border-width: 1px; border-color: #ffffff14;
                        cncta := TouchArea {
                            clicked => { root.show-confirm-exit = false; }
                            mouse-cursor: pointer;
                        }
                        Text {
                            text: "Отмена";
                            color: #929292; font-size: 13.5px; font-weight: 600;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ── Unsaved settings warning ───────────────────────────────────────────────
    if root.show-unsaved-warning : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #00000099;

        TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

        Rectangle {
            x: (parent.width - 460px) / 2;
            y: (parent.height - 220px) / 2;
            width: 460px; height: 220px;
            border-radius: 14px;
            background: #252525;
            border-width: 1px; border-color: #ffffff18;
            drop-shadow-blur: 48px; drop-shadow-color: #000000cc;

            TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

            VerticalLayout {
                padding: 26px; spacing: 0px;

                Text {
                    text: "Несохранённые изменения";
                    color: #e5e5e5; font-size: 15px; font-weight: 700;
                }
                Rectangle { height: 8px; }
                Text {
                    text: "Настройки были изменены. Сохранить перед переходом?";
                    color: #6b6b6b; font-size: 13px; wrap: word-wrap;
                }
                Rectangle { height: 22px; }

                HorizontalLayout {
                    spacing: 8px; height: 42px;

                    Rectangle {
                        horizontal-stretch: 1; border-radius: 9px;
                        background: usw-save.has-hover ? #46c07a : #3ca96e;
                        usw-save := TouchArea {
                            clicked => {
                                root.save-settings();
                                root.show-unsaved-warning = false;
                                root.active-tab = 0;
                            }
                            mouse-cursor: pointer;
                        }
                        Text {
                            text: "Сохранить";
                            color: #101c12; font-size: 13.5px; font-weight: 700;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1; border-radius: 9px;
                        background: usw-disc.has-hover ? #333333 : #2c2c2c;
                        border-width: 1px; border-color: #ffffff14;
                        usw-disc := TouchArea {
                            clicked => {
                                root.reload-settings();
                                root.show-unsaved-warning = false;
                                root.active-tab = 0;
                            }
                            mouse-cursor: pointer;
                        }
                        Text {
                            text: "Отменить изменения";
                            color: #929292; font-size: 13px; font-weight: 600;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 100px; border-radius: 9px;
                        background: usw-stay.has-hover ? #333333 : #272727;
                        border-width: 1px; border-color: #ffffff10;
                        usw-stay := TouchArea {
                            clicked => { root.show-unsaved-warning = false; }
                            mouse-cursor: pointer;
                        }
                        Text {
                            text: "Остаться";
                            color: #555555; font-size: 13px; font-weight: 600;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ── No-render confirmation dialog ─────────────────────────────────────────
    if root.show-render-confirm : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #00000099;

        TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

        Rectangle {
            x: (parent.width - 460px) / 2;
            y: (parent.height - 210px) / 2;
            width: 460px; height: 210px;
            border-radius: 14px;
            background: #252525;
            border-width: 1px; border-color: #ae3c2c80;
            drop-shadow-blur: 48px; drop-shadow-color: #000000cc;

            TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

            VerticalLayout {
                padding: 26px; spacing: 0px;

                Text {
                    text: "Режим без рендера";
                    color: #e5e5e5; font-size: 15px; font-weight: 700;
                }
                Rectangle { height: 8px; }
                Text {
                    text: "Этот режим крайне нестабилен и часто вызывает вылеты Squad. Рекомендуется использовать только если вы знаете что делаете.";
                    color: #d4816e; font-size: 13px; wrap: word-wrap;
                }
                Rectangle { height: 22px; }

                HorizontalLayout {
                    spacing: 10px; height: 42px;

                    Rectangle {
                        horizontal-stretch: 1; border-radius: 9px;
                        background: rcon-ta.has-hover ? #b54040 : #a13a3a;
                        rcon-ta := TouchArea {
                            clicked => {
                                root.cfg-render-toggle = true;
                                root.show-render-confirm = false;
                            }
                            mouse-cursor: pointer;
                        }
                        Text {
                            text: "Включить";
                            color: #f5e5e0; font-size: 13.5px; font-weight: 700;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 115px; border-radius: 9px;
                        background: rcnc-ta.has-hover ? #333333 : #2c2c2c;
                        border-width: 1px; border-color: #ffffff14;
                        rcnc-ta := TouchArea {
                            clicked => { root.show-render-confirm = false; }
                            mouse-cursor: pointer;
                        }
                        Text {
                            text: "Отмена";
                            color: #929292; font-size: 13.5px; font-weight: 600;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ── Validation error dialog ────────────────────────────────────────────────
    if root.show-validation-error : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #00000099;

        TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

        Rectangle {
            x: (parent.width - 430px) / 2;
            y: (parent.height - 180px) / 2;
            width: 430px; height: 180px;
            border-radius: 14px;
            background: #252525;
            border-width: 1px; border-color: #ae3c2c80;
            drop-shadow-blur: 48px; drop-shadow-color: #000000cc;

            TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }

            VerticalLayout {
                padding: 26px; spacing: 0px;

                Text {
                    text: "Ошибка запуска";
                    color: #e5e5e5; font-size: 15px; font-weight: 700;
                }
                Rectangle { height: 8px; }
                Text {
                    text: root.validation-error-msg;
                    color: #d4816e; font-size: 13px; wrap: word-wrap;
                }
                Rectangle { height: 22px; }

                HorizontalLayout {
                    height: 42px; alignment: end;
                    Rectangle {
                        width: 115px; border-radius: 9px;
                        background: okta.has-hover ? #333333 : #2c2c2c;
                        border-width: 1px; border-color: #ffffff14;
                        okta := TouchArea {
                            clicked => { root.show-validation-error = false; }
                            mouse-cursor: pointer;
                        }
                        Text {
                            text: "ОК";
                            color: #929292; font-size: 13.5px; font-weight: 600;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ── After-hours warning ────────────────────────────────────────────────────
    if root.show-after-hours-prompt : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #00000099;
        TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 480px) / 2;
            y: (parent.height - 220px) / 2;
            width: 480px; height: 220px;
            border-radius: 14px; background: #252525;
            border-width: 1px; border-color: #ae3c2c80;
            drop-shadow-blur: 48px; drop-shadow-color: #000000cc;
            TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }
            VerticalLayout {
                padding: 26px; spacing: 0px;
                Text { text: "Лимит времени сидинга"; color: #e5e5e5; font-size: 15px; font-weight: 700; }
                Rectangle { height: 8px; }
                Text {
                    text: "Установленный лимит времени уже наступил. Хотите продолжить сидинг?";
                    color: #d4816e; font-size: 13px; wrap: word-wrap;
                }
                Rectangle { height: 22px; }
                HorizontalLayout {
                    spacing: 8px; height: 42px;
                    Rectangle {
                        horizontal-stretch: 1; border-radius: 9px;
                        background: ah-yes.has-hover ? #46c07a : #3ca96e;
                        ah-yes := TouchArea {
                            clicked => { root.show-after-hours-prompt = false; root.force-start-seed(); }
                            mouse-cursor: pointer;
                        }
                        Text { text: "Продолжить"; color: #101c12; font-size: 13.5px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    if root.after-hours-is-auto : Rectangle {
                        horizontal-stretch: 1; border-radius: 9px;
                        background: ah-exit.has-hover ? #b54040 : #a13a3a;
                        ah-exit := TouchArea {
                            clicked => { root.show-after-hours-prompt = false; root.exit-app(); }
                            mouse-cursor: pointer;
                        }
                        Text { text: "Выйти"; color: #f5e5e0; font-size: 13.5px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Rectangle {
                        width: 100px; border-radius: 9px;
                        background: ah-cancel.has-hover ? #333333 : #272727;
                        border-width: 1px; border-color: #ffffff10;
                        ah-cancel := TouchArea {
                            clicked => { root.show-after-hours-prompt = false; }
                            mouse-cursor: pointer;
                        }
                        Text { text: "Отмена"; color: #555555; font-size: 13px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }
    }

    // ── After-seed action confirmation ────────────────────────────────────────
    if root.show-after-seed-confirm : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #00000099;
        TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 480px) / 2;
            y: (parent.height - 230px) / 2;
            width: 480px; height: 230px;
            border-radius: 14px; background: #252525;
            border-width: 1px; border-color: #ae3c2c80;
            drop-shadow-blur: 48px; drop-shadow-color: #000000cc;
            TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }
            VerticalLayout {
                padding: 26px; spacing: 0px;
                Text { text: "Seeding завершён"; color: #e5e5e5; font-size: 15px; font-weight: 700; }
                Rectangle { height: 8px; }
                Text {
                    text: "Запланированное действие: \{root.after-seed-confirm-msg}\nВыполнить? (авто-выполнение через 60 сек)";
                    color: #d4816e; font-size: 13px; wrap: word-wrap;
                }
                Rectangle { height: 22px; }
                HorizontalLayout {
                    spacing: 8px; height: 42px;
                    Rectangle {
                        horizontal-stretch: 1; border-radius: 9px;
                        background: asc-yes.has-hover ? #b54040 : #a13a3a;
                        asc-yes := TouchArea {
                            clicked => { root.confirm-after-seed-proceed(); }
                            mouse-cursor: pointer;
                        }
                        Text { text: "Выполнить"; color: #f5e5e0; font-size: 13.5px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Rectangle {
                        width: 115px; border-radius: 9px;
                        background: asc-no.has-hover ? #333333 : #2c2c2c;
                        border-width: 1px; border-color: #ffffff14;
                        asc-no := TouchArea {
                            clicked => { root.confirm-after-seed-cancel(); }
                            mouse-cursor: pointer;
                        }
                        Text { text: "Отмена"; color: #929292; font-size: 13.5px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }
    }

    // ── Steam not running prompt ───────────────────────────────────────────────
    if root.show-steam-prompt : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #00000099;
        TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 400px) / 2;
            y: (parent.height - 180px) / 2;
            width: 400px; height: 180px;
            border-radius: 14px; background: #252525;
            border-width: 1px; border-color: #ffffff18;
            drop-shadow-blur: 48px; drop-shadow-color: #000000cc;
            TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }
            VerticalLayout {
                padding: 26px; spacing: 0px;
                Text { text: "Steam не запущен"; color: #e5e5e5; font-size: 15px; font-weight: 700; }
                Rectangle { height: 8px; }
                Text { text: "Хотите сначала открыть Steam?"; color: #6b6b6b; font-size: 13px; }
                Rectangle { height: 22px; }
                HorizontalLayout {
                    spacing: 10px; height: 42px;
                    Rectangle {
                        horizontal-stretch: 1; border-radius: 9px;
                        background: sp-yes.has-hover ? #46c07a : #3ca96e;
                        sp-yes := TouchArea {
                            clicked => { root.open-steam-click(); root.show-steam-prompt = false; }
                            mouse-cursor: pointer;
                        }
                        Text { text: "Да, открыть"; color: #101c12; font-size: 13.5px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Rectangle {
                        width: 115px; border-radius: 9px;
                        background: sp-no.has-hover ? #333333 : #2c2c2c;
                        border-width: 1px; border-color: #ffffff14;
                        sp-no := TouchArea { clicked => { root.show-steam-prompt = false; } mouse-cursor: pointer; }
                        Text { text: "Отмена"; color: #929292; font-size: 13.5px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }
    }

    // ── Squad not running prompt ───────────────────────────────────────────────
    if root.show-squad-prompt : Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;
        background: #00000099;
        TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }
        Rectangle {
            x: (parent.width - 430px) / 2;
            y: (parent.height - 210px) / 2;
            width: 430px; height: 210px;
            border-radius: 14px; background: #252525;
            border-width: 1px; border-color: #ffffff18;
            drop-shadow-blur: 48px; drop-shadow-color: #000000cc;
            TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; }
            VerticalLayout {
                padding: 26px; spacing: 0px;
                Text { text: "Squad не запущен"; color: #e5e5e5; font-size: 15px; font-weight: 700; }
                Rectangle { height: 8px; }
                Text {
                    text: "Squad должен быть запущен для подключения к серверу. Запустить Squad и подключиться?";
                    color: #6b6b6b; font-size: 13px; wrap: word-wrap;
                }
                Rectangle { height: 22px; }
                HorizontalLayout {
                    spacing: 10px; height: 42px;
                    Rectangle {
                        horizontal-stretch: 1; border-radius: 9px;
                        background: sqp-yes.has-hover ? #46c07a : #3ca96e;
                        sqp-yes := TouchArea {
                            clicked => { root.launch-squad-and-join(root.pending-join-server); root.show-squad-prompt = false; }
                            mouse-cursor: pointer;
                        }
                        Text { text: "Да, запустить"; color: #101c12; font-size: 13.5px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Rectangle {
                        width: 115px; border-radius: 9px;
                        background: sqp-no.has-hover ? #333333 : #2c2c2c;
                        border-width: 1px; border-color: #ffffff14;
                        sqp-no := TouchArea { clicked => { root.show-squad-prompt = false; } mouse-cursor: pointer; }
                        Text { text: "Отмена"; color: #929292; font-size: 13.5px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }
    }

    } // end root Rectangle
}
